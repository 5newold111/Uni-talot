+// 明日の占い：日付と端末から札を自動決定（同じ明日は何度視ても同じ札）
+function tomorrowPick() {
+  const d = new Date(); d.setDate(d.getDate() + 1);
+  const key = d.getFullYear() * 10000 + (d.getMonth() + 1) * 100 + d.getDate();
+  let salt = 0;
+  try {
+    salt = Number(localStorage.getItem("uni_salt")) || 0;
+    if (!salt) { salt = Math.floor(Math.random() * 1e9) + 1; localStorage.setItem("uni_salt", String(salt)); }
+  } catch (e) { salt = 123457; }
+  let x = (key ^ salt) &gt;&gt;&gt; 0;
+  x ^= x &lt;&lt; 13; x &gt;&gt;&gt;= 0; x ^= x &gt;&gt; 17; x ^= x &lt;&lt; 5; x &gt;&gt;&gt;= 0;
+  return {
+    card: TAROT_CARDS[x % 22],
+    reversed: ((x &gt;&gt; 8) &amp; 1) === 1,
+    dateLabel: `${d.getMonth() + 1}月${d.getDate()}日`
+  };
+}
+
+function startTomorrow() {
+  const pick = tomorrowPick();
+  state.mode = "tomorrow";
+  state.theme = "general";
+  state.concern = "";
+  state.spread = "tomorrow";
+  state.needed = 1;
+  state.picks = [{ card: pick.card, reversed: pick.reversed }];
+  state.tomorrowDate = pick.dateLabel;
+  gazeThenReveal();   // 札引き画面を飛ばして、水晶玉演出→結果へ
+}
