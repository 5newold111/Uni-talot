FAL_API_KEY=your_fal_api_key_here
HOMESTYLER_EMAIL=your_email_here
HOMESTYLER_PASSWORD=your_password_here
BLENDER_PATH=/usr/bin/blender
PORT=3000
# 認証 (空文字なら認証スキップ。設定すると拡張機能と同じ値を送る必要あり)
EC3D_API_KEY=
# SQLite ジョブ DB のパス
JOB_DB_PATH=jobs.db
# ===== 3D 生成プロバイダー =====
#  tripo         (default): fal.ai 経由 (1個 5〜50円)。FAL_API_KEY 必須
#  colab_trellis : Google Colab で立てた TRELLIS バックエンド (完全無料)。
#                  docs/trellis_colab.ipynb を Colab で実行 → 表示された ngrok URL を
#                  TRELLIS_COLAB_URL に貼ってください
#  hf_space      : HuggingFace Space (将来対応)
MODEL_PROVIDER=tripo
TRELLIS_COLAB_URL=https://your-ngrok-url-here.ngrok-free.app
