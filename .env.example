# ── Gemini（トレンド分析・ブリーフ生成）──
# https://aistudio.google.com/apikey （無料枠あり）
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ── SUNO（楽曲生成・非公式 API）──
SUNO_API_KEY=
SUNO_BASE_URL=
SUNO_POLL_TIMEOUT=300

# ── DistroKid 自動操作（任意・--upload playwright 時のみ）──
# 自分のアカウントに対してのみ使用し、利用規約を順守すること。
DISTROKID_EMAIL=
DISTROKID_PASSWORD=

# ── 通知（任意・半自動配信のリマインド用）──
NOTIFY_EMAIL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# ── 動作モード ──
# 1 を設定すると外部 API を一切呼ばず、ダミー出力で全工程を動かします（CI/開発用）。
# 未設定でも、対応する API キーが無い工程は自動的にモックになります。
MUSIC_PIPELINE_MOCK=
