# ===== データバックエンド =====
# sheets = Google スプレッドシートを使用 / memory = インメモリ（デモ・テスト用）
# 未指定の場合、Google認証情報が揃っていれば sheets、無ければ memory に自動フォールバック
DATA_BACKEND=

# ===== Google Sheets 連携 =====
# Google Cloud でサービスアカウントを作成し、Sheets API を有効化してください。
# 作成したスプレッドシートを、このサービスアカウントのメールアドレスに「編集者」で共有します。
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# サービスアカウントの秘密鍵（JSONの private_key の値）。改行は \n のままでOK。
GOOGLE_PRIVATE_KEY=
# 使用するスプレッドシートのID（URLの /d/ と /edit の間の文字列）
# 空の場合、npm run sheets:setup が新規作成してIDを表示します。
GOOGLE_SHEETS_SPREADSHEET_ID=
